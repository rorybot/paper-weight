[Unit]
Description=Paper Weight Car Thing input bridge
After=local-fs.target
Before=kiosk.service

[Service]
Type=simple
User=paper-weight
Group=paper-weight
SupplementaryGroups=input
ExecStart=/opt/paper-weight/bin/input_bridge --config /etc/paper-weight/input-bridge.conf
Restart=on-failure
RestartSec=1
NoNewPrivileges=true
ProtectHome=true
ProtectSystem=strict
PrivateTmp=true

[Install]
WantedBy=multi-user.target


# Copy to `.env` (never commit) for local host services.
# Location is intentionally not defaulted in code.

# Weather (NWS + OpenUV)
WEATHER_LAT=
WEATHER_LON=
WEATHER_LOCATION_LABEL=local
# WEATHER_USER_AGENT=paper-weight/0.1 (your contact; NWS requires a descriptive UA)
OPENUV_API_KEY=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

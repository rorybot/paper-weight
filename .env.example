# Copy to `.env` (never commit) for local host services.
# Location is intentionally not defaulted in code.
#
# Full contract (precedence, validation, systemd wiring):
# docs/architecture/live-runtime-contract-v1.md

# Per-lane enable/disable (true/1/enabled or false/0/disabled; unset = compiled
# default). PAPER_WEIGHT_GATEWAY_STUBS=all (below) overrides all three off.
# PAPER_WEIGHT_WEATHER_ENABLED=true
# PAPER_WEIGHT_SPOTIFY_ENABLED=true
# PAPER_WEIGHT_FEED_ENABLED=true

# Fixture/stub gateway profile — set to none (or unset) to use the vars below.
# PAPER_WEIGHT_GATEWAY_STUBS=all

# Weather (NWS + OpenUV)
WEATHER_LAT=
WEATHER_LON=
WEATHER_LOCATION_LABEL=local
# WEATHER_USER_AGENT=paper-weight/0.1 (your contact; NWS requires a descriptive UA)
OPENUV_API_KEY=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Feed
PAPER_WEIGHT_FEED_HANDLES=
PAPER_WEIGHT_FEED_LIST_ID=
PAPER_WEIGHT_FEED_LIMIT=
PAPER_WEIGHT_FEED_REFRESH_MS=
PAPER_WEIGHT_FEED_API_TOKEN=
